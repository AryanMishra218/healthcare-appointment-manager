# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to GitHub -- it's in .gitignore already.

SECRET_KEY=YOUR SECRET KEY

# Leave blank locally -- uses a local SQLite file automatically.
# On Render, paste your PostgreSQL URL here.
DATABASE_URL= YOUR DATABASE URL
#Google Gemini API key (free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY= YOUR GEMINI API KEY

#Gmail SMTP (free): use your Gmail + an App Password
# How to get App Password: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS= your_email@gmail.com
GMAIL_APP_PASSWORD= your_app_password

#Google Calendar OAuth: https://console.cloud.google.com
GOOGLE_CLIENT_ID= YOUR GOOGLE CLIENT ID  
GOOGLE_CLIENT_SECRET= YOUR GOOGLE CLIENT SECRET
